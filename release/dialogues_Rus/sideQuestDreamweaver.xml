<dialogue checksum="95eec62f0d3c60334b7440daf135f8561a0fcf70" name="sideQuestDreamweaver" entry="intro">
  <choices id="intro" title="STR_INTRO_6">
    <choice title="Мне сказали поговорить с тобой об этом кулоне." response="А, это будет четыре-двадцать." result="" next="intro_desc_1"/>
    <choice title="Я хочу ещё три желания... и мира во всём мире." response="Итак, мисс Подземелье, чего ты на самом деле хочешь?" result="" next="intro_reply"/>
    <choice title="Я хочу всё, что у тебя есть!" response="STR_FUBAR" result="SET_ENEMY" next=""/>
  </choices>
  <choices id="intro_reply" title="STR_INTRO_6">
