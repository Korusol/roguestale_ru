  <choices id="intro_desc_4" title="Это будет четыре-двадцать.">
    <choice title="О, ладно, вот, возьми мои деньги." response="STR_BUY[Dreamweave,420]" result="CLOSE_DIALOGUE" next="intro_desc_5"/>
