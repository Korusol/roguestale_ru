  <choices id="intro_desc_2" title="Это будет четыре-двадцать.">
    <choice title="Что я получу за все эти золотые монеты?" response="То, за чем ты сюда пришёл." result="" next="intro_desc_3"/>
    <choice title="Как насчёт ноля золотых и разбитого черепа?" response="STR_FUBAR" result="SET_ENEMY" next=""/>
