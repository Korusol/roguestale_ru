<dialogue checksum="661392e5ea38a723d2cf30da1a774797f6a5cb08" name="sideQuestSkaldir" entry="intro">
  <choices id="intro" title="Чую человека!">
    <choice title="Гм, костяная работа делает это крайне маловероятным." response="Молчи, дурак!" result="" next="intro_reply_1"/>
    <choice title="Ты нашёл меня, теперь укажи мне на сокровище." response="Единственное сокровище, которое ты здесь найдёшь — это смерть!" result="" next="intro_reply_1"/>
  </choices>
  <choices id="intro_reply_1" title="">
    <choice title="А вот и бессмысленные угрозы." response="Наглость в этом сильна!" result="" next="intro_reply_2"/>
    <choice title="Тик-так, я возбуждён жаждой убийства." response="Тик-так... Вот именно!" result="" next="intro_reply_2"/>
  </choices>
  <choices id="intro_reply_2" title="">
    <choice title="Ну что, мы уже на месте?" response="Да, твоё время вышло!" result="" next="intro_reply_3"/>
  </choices>
  <choices id="intro_reply_3" title="">
    <choice title="Я решаю, когда моё время истекло." response="Простак, я вне времени, и я правлю временем!" result="" next="intro_reply_4"/>
    <choice title="Давай без болтовни." response="Пусть будет по-твоему." result="SET_ENEMY" next=""/>
  </choices>
  <choices id="intro_reply_4" title="">
    <choice title="Продолжай, хочешь ещё что-нибудь рассказать?" response="Гм... Неа, ничего!" result="" next="intro_reply_5"/>
    <choice title="Давай без болтовни." response="Пусть будет по-твоему." result="SET_ENEMY" next=""/>
  </choices>
  <choices id="intro_reply_5" title="">
    <choice title="И вот всё рушится, как карточный домик." response="Ты не заставишь меня изменить свой экологический след!" result="" next="intro_reply_6"/>
    <choice title="Давай без болтовни." response="Пусть будет по-твоему." result="SET_ENEMY" next=""/>
  </choices>
  <choices id="intro_reply_6" title="">
    <choice title="Надеюсь, страховка твоего хозяина покрывает тебя." response="Тебе не нужно об этом беспокоиться!" result="" next="intro_reply_7"/>
    <choice title="Давай без болтовни." response="Пусть будет по-твоему." result="SET_ENEMY" next=""/>
  </choices>
  <choices id="intro_reply_7" title="">
    <choice title="Я буду архитектором твоей гибели." response="Тебе понадобится больше огневой мощи!" result="" next="intro_reply_8"/>
    <choice title="Давай без болтовни." response="Пусть будет по-твоему." result="SET_ENEMY" next=""/>
  </choices>
  <choices id="intro_reply_8" title="">
    <choice title="Я превращу тебя в печь, если понадобится." response="Я сделан из асбеста, так что удачи!" result="" next="intro_reply_9"/>
    <choice title="Давай без болтовни." response="Пусть будет по-твоему." result="SET_ENEMY" next=""/>
  </choices>
  <choices id="intro_reply_9" title="">
    <choice title="Мы закончили с ментальной гимнастикой?" response="Это ты ещё говоришь!" result="" next="intro_reply_10"/>
    <choice title="Давай без болтовни." response="Пусть будет по-твоему." result="SET_ENEMY" next=""/>
  </choices>
  <choices id="intro_reply_10" title="">
    <choice title="Ок, давай закончим это." response="Хм, плевать." result="SET_ENEMY" next=""/>
  </choices>
  <choices id="set_enemy" title="Ха-ха-ха, корми меня своей злостью!">
    <choice title="Почему бы тебе просто не умереть?" response="Потому что геймеры убили всех простых боссов!" result="SET_ENEMY" next=""/>
  </choices>
</dialogue>
