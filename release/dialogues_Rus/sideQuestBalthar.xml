<dialogue checksum="9e383ed549276a5495e1d75b3254513564327880" name="sideQuestBalthar" entry="intro">
  <choices id="intro" title="Мастер!">
    <choice title="Эм, да?" response="Я выучил новый трюк." result="" next="intro_reply_1"/>
  </choices>
  <choices id="intro_reply_1" title="">
    <choice title="Вау, что это?" response="Я могу сжечь ману у всех." result="" next="intro_reply_2"/>
  </choices>
  <choices id="intro_reply_2" title="">
    <choice title="Значит, это сделал ты?" response="Да, разве не прекрасно!" result="" next="intro_reply_3"/>
  </choices>
  <choices id="intro_reply_3" title="">
    <choice title="Эти трупы могут не согласиться с тобой." response="Но теперь я свободен от тыканий." result="" next="intro_reply_4"/>
  </choices>
  <choices id="intro_reply_4" title="">
    <choice title="Тыкание?" response="Да, эти злые люди тыкали в меня!" result="" next="intro_reply_5"/>
  </choices>
  <choices id="intro_reply_5" title="">
    <choice title="Тыкал тебя, как меня, или?" response="Нет, фу, острыми предметами." result="" next="intro_reply_6"/>
  </choices>
  <choices id="intro_reply_6" title="">
    <choice title="О, ладно, нормально." response="Это НОРМАЛЬНО?" result="" next="intro_reply_7"/>
  </choices>
  <choices id="intro_reply_7" title="">
    <choice title="Оо, это прозвучало неправильно." response="Ты здесь, чтобы ТЫКАТЬ в меня?" result="" next="intro_reply_8"/>
  </choices>
  <choices id="intro_reply_8" title="">
    <choice title="Гм, нет?" response="Лжец, лжец, гори, ГОРИ!" result="" next="intro_reply_9"/>
  </choices>
  <choices id="intro_reply_9" title=" ">
    <choice title="Пока ты совсем не спятил..." response="ЧТО?" result="" next="intro_reply_10"/>
  </choices>
  <choices id="intro_reply_10" title=" ">
    <choice title="Как работает этот ожог маны?" response="Я вижу в тебе синий свет." result="" next="intro_reply_11"/>
  </choices>
  <choices id="intro_reply_11" title=" ">
    <choice title="И?" response="Я поджёг это, огонь, ОГОНЬ!" result="SET_ENEMY" next=""/>
  </choices>
</dialogue>
